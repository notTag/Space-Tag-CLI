#!/usr/bin/env bash
# sketchybar — transparent overlay on the native macOS menu bar.
# Renders one centered pill per macOS space, label = yabai label.
# Click a pill → focus that space. Bar follows the focused display.

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# Theme + tuning constants (colors, geometry, fonts, animation).
. "$HOME/.config/sketchybar/theme.sh"

# ─── bar ──────────────────────────────────────────────────────────────────
# Transparent bg + ~native height so pills appear "inside" the macOS menu bar.
# y_offset is set/refreshed by plugins/y_offset.sh based on whether the
# active display is notched. We boot with the flat default; the watcher
# below applies the correct value on display_change (and once at startup).
sketchybar --bar \
  height="$BAR_HEIGHT" \
  position=top \
  y_offset="$Y_OFFSET_FLAT" \
  padding_left=8 \
  padding_right=8 \
  color="$COLOR_BAR_BG" \
  border_width=0 \
  shadow=off \
  blur_radius=0 \
  topmost=on

# ─── defaults ────────────────────────────────────────────────────────────
sketchybar --default \
  updates=when_shown \
  icon.font="$FONT_ICON" \
  label.font="$FONT_LABEL" \
  icon.color="$COLOR_PILL_FG" \
  label.color="$COLOR_PILL_FG" \
  padding_left=4 \
  padding_right=4

# ─── space pills (centered) ──────────────────────────────────────────────
# Build one item per current space. The space.sh plugin renders the label
# from yabai's stored space label and highlights focused space.
# At boot, sketchybar's launchd may fire before yabai's socket is ready;
# retry the query for up to ~10s so reboots come up with pills populated.
SPACE_IDS=""
for _ in $(seq 1 20); do
  SPACE_IDS=$("$YABAI" -m query --spaces 2>/dev/null | "$JQ" -r '.[].index' 2>/dev/null)
  [ -n "$SPACE_IDS" ] && break
  sleep 0.5
done

if [ -z "$SPACE_IDS" ]; then
  echo "sketchybar: yabai not responding after 10s, skipping space items." >&2
else
  for sid in $SPACE_IDS; do
    sketchybar --add item space.$sid center \
               --set space.$sid \
                   icon="$sid" \
                   icon.padding_left=10 \
                   background.color="$COLOR_PILL_BG" \
                   background.corner_radius="$PILL_CORNER_RADIUS" \
                   background.height="$PILL_HEIGHT" \
                   click_script="$YABAI -m space --focus $sid" \
                   script="$PLUGIN_DIR/space.sh" \
               --subscribe space.$sid space_change
  done
fi

# ─── re-apply y_offset + pin to active display on display change ─────────
sketchybar --add item y_offset_watcher left \
           --set y_offset_watcher drawing=off updates=on \
               script="$PLUGIN_DIR/y_offset.sh" \
           --subscribe y_offset_watcher display_change

# Apply once at boot so the active display gets the correct offset
# without waiting for the first display_change event.
"$PLUGIN_DIR/y_offset.sh"

sketchybar --update
echo "sketchybar config loaded."
