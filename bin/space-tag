#!/bin/sh
# space-tag — tag macOS spaces with project names (yabai + sketchybar + jq).
# Standalone POSIX script: works from any shell, keybinding, or script.
# Auto-tag-on-cd lives in shell/space-tag.{zsh,bash}, which call
# `space-tag __autotag` on directory change.
#
# usage:
#   space-tag <name> [space#]          tag a space (current space if no number)
#   space-tag -- <name> [space#]       tag with a literal name (escapes reserved words)
#   space-tag clear                    clear the current space's tag
#   space-tag auto [on|off]            get/set auto-tagging on cd
#   space-tag display [current|all]    get/set which spaces the bar shows
#   space-tag position [<mode>]        get/set pill placement for THIS display
#   space-tag position default <mode>  set fallback for displays without their own setting
#   space-tag position clear           drop this display's setting (fall back to default)
#   space-tag position list            show the default and every per-display override
#   space-tag reload                   reload sketchybar (re-reads configs + theme)
#   space-tag source                   reload your shell (handled by the shell hook)
#   space-tag help                     show this help

set -u

CFG="$HOME/.config/sketchybar"

die() { echo "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
space-tag — tag macOS spaces (yabai + sketchybar)

usage:
  space-tag <name> [space#]          tag a space (current space if no number)
  space-tag -- <name> [space#]       tag with a literal name (escapes reserved words)
  space-tag clear                    clear the current space's tag
  space-tag auto [on|off]            get/set auto-tagging on cd
  space-tag display [current|all]    get/set which spaces the bar shows
                                       current = focused display's spaces only (default)
                                       all     = every space across all displays
  space-tag position [<mode>]        get/set pill placement for THIS display
  space-tag position default <mode>  set fallback for displays without their own setting
  space-tag position clear           drop this display's setting (fall back to default)
  space-tag position list            show the default and every per-display override
  space-tag reload                   reload sketchybar (re-reads configs + theme)
  space-tag source                   reload your shell (handled by the shell hook)
  space-tag help                     show this help

position modes: center | notch-left | notch-right | left | right
EOF
}

active_space() {
  yabai -m query --spaces --space 2>/dev/null | jq -r '.index // empty'
}

active_display_uuid() {
  yabai -m query --displays --display 2>/dev/null | jq -r '.uuid // empty'
}

# Fire a sketchybar trigger without blocking the caller.
refresh() {
  sketchybar --trigger "$1" >/dev/null 2>&1 &
}

# ─── tag (default action) ────────────────────────────────────────────────

tag_space() {
  name=$1
  sid=${2:-}
  if [ -n "$sid" ]; then
    case $sid in *[!0-9]*) die "space number must be numeric: $sid" ;; esac
  else
    sid=$(active_space)
    [ -n "$sid" ] || die "no active space"
  fi
  yabai -m space "$sid" --label "$name" || exit 1
  refresh space_change
  echo "space $sid → $name"
}

cmd_clear() {
  sid=$(active_space)
  [ -n "$sid" ] || die "no active space"
  yabai -m space "$sid" --label "" || exit 1
  refresh space_change
  echo "space $sid → (cleared)"
}

# ─── auto-tagging toggle ─────────────────────────────────────────────────
# State persists to ~/.config/sketchybar/auto-tag so it survives new shells.
# For a one-off override in the current shell, export SPACE_TAG_AUTO=off.

cmd_auto() {
  file="$CFG/auto-tag"
  legacy="$CFG/auto-label"
  case "${1:-}" in
    "")
      cur=$(cat "$file" 2>/dev/null || cat "$legacy" 2>/dev/null)
      [ "$cur" = off ] && echo off || echo on
      ;;
    on|off)
      mkdir -p "$CFG"
      printf '%s\n' "$1" > "$file"
      echo "auto-tag → $1"
      ;;
    *) die "usage: space-tag auto [on|off]" ;;
  esac
}

# ─── per-display spaces ──────────────────────────────────────────────────
# current = show only the focused display's spaces (default); all = every
# space across all displays. The persisted file keeps the legacy on/off
# values (on = current) because spaces.sh reads it directly.

cmd_display() {
  file="$CFG/per-display-spaces"
  case "${1:-}" in
    "")
      [ "$(cat "$file" 2>/dev/null)" = off ] && echo all || echo current
      ;;
    current|all)
      state=on
      [ "$1" = all ] && state=off
      mkdir -p "$CFG"
      printf '%s\n' "$state" > "$file"
      refresh space_set_change
      echo "display → $1"
      ;;
    *) die "usage: space-tag display [current|all]" ;;
  esac
}

# ─── pill position, remembered PER DISPLAY ───────────────────────────────
# Each physical display is keyed by its stable yabai UUID; setting a mode
# while focused on a display persists that display's choice to
# ~/.config/sketchybar/position.d/<uuid>. layout.sh applies the focused
# display's mode, falling back to the shared default
# (~/.config/sketchybar/position), then center.

valid_mode() {
  case "$1" in center|notch-left|notch-right|left|right) return 0 ;; *) return 1 ;; esac
}

cmd_position() {
  pos_file="$CFG/position"
  pos_dir="$CFG/position.d"
  pos_usage="usage: space-tag position [<mode>|default <mode>|clear|list]   mode ∈ {center,notch-left,notch-right,left,right}"
  case "${1:-}" in
    "")  # show this display's effective mode + where it came from
      active=$(active_display_uuid)
      if [ -n "$active" ] && [ -f "$pos_dir/$active" ]; then
        echo "$(cat "$pos_dir/$active")  (this display)"
      else
        echo "$(cat "$pos_file" 2>/dev/null || echo center)  (default)"
      fi
      ;;
    list)
      echo "default      $(cat "$pos_file" 2>/dev/null || echo center)"
      active=$(active_display_uuid)
      for f in "$pos_dir"/*; do
        [ -e "$f" ] || continue
        u=$(basename "$f")
        if [ "$u" = "$active" ]; then
          echo "$u  $(cat "$f")  <- this display"
        else
          echo "$u  $(cat "$f")"
        fi
      done
      ;;
    clear)
      active=$(active_display_uuid)
      [ -n "$active" ] || die "no active display (is yabai running?)"
      rm -f "$pos_dir/$active"
      refresh position_change
      echo "this display ($active) → default"
      ;;
    default)
      valid_mode "${2:-}" || die "$pos_usage"
      mkdir -p "$CFG"
      printf '%s\n' "$2" > "$pos_file"
      refresh position_change
      echo "default position → $2"
      ;;
    *)
      valid_mode "$1" || die "$pos_usage"
      active=$(active_display_uuid)
      [ -n "$active" ] || die "no active display (is yabai running?)"
      mkdir -p "$pos_dir"
      printf '%s\n' "$1" > "$pos_dir/$active"
      refresh position_change
      echo "this display ($active) → $1"
      ;;
  esac
}

# ─── reload: wrapper for sketchybar --reload ─────────────────────────────
# One CLI surface for the whole tool — re-reads sketchybarrc, theme, plugins.

cmd_reload() {
  command -v sketchybar >/dev/null 2>&1 || die "sketchybar not found"
  sketchybar --reload || exit 1
  echo "sketchybar reloaded"
}

# ─── __autotag: called by the shell hooks on cd ──────────────────────────
# Tags the active space with the git repo basename, honoring the auto
# toggle: SPACE_TAG_AUTO env var wins (per-shell override), otherwise the
# persisted state. Falls back to the legacy auto-label file so a
# previously-disabled state survives the space-label → space-tag rename.
# Always exits 0 — a failed auto-tag must never surface in the shell.

cmd_autotag() {
  auto=${SPACE_TAG_AUTO:-$(cat "$CFG/auto-tag" 2>/dev/null || cat "$CFG/auto-label" 2>/dev/null)}
  [ "$auto" = off ] && exit 0
  command -v yabai >/dev/null 2>&1 || exit 0
  command -v jq    >/dev/null 2>&1 || exit 0
  root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
  name=$(basename "$root")
  sid=$(active_space)
  [ -n "$sid" ] || exit 0
  yabai -m space "$sid" --label "$name" 2>/dev/null
  command -v sketchybar >/dev/null 2>&1 && refresh space_change
  exit 0
}

# ─── dispatch ────────────────────────────────────────────────────────────

case "${1:-}" in
  "")              usage >&2; exit 1 ;;
  help|-h|--help)  usage ;;
  clear)           shift; cmd_clear "$@" ;;
  auto)            shift; cmd_auto "$@" ;;
  display)         shift; cmd_display "$@" ;;
  position)        shift; cmd_position "$@" ;;
  reload)          cmd_reload ;;
  source)          # a child process can't exec the parent shell; the hook
                   # shims define a `space-tag` wrapper fn that handles this
                   die "space-tag source needs the shell hook loaded (shell/space-tag.zsh or .bash) — reload manually with: exec \$SHELL" ;;
  __autotag)       cmd_autotag ;;
  --)              shift
                   [ $# -ge 1 ] || die "usage: space-tag -- <name> [space#]"
                   tag_space "$@" ;;
  -*)              die "unknown option: $1 (use 'space-tag -- $1' to tag with that literal name)" ;;
  *)               tag_space "$@" ;;
esac
